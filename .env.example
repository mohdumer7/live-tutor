# LiveKit Cloud — get from https://cloud.livekit.io
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Public URL for the browser client (must be the wss:// LiveKit URL)
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# Google AI Studio — Gemini 2.5 Live
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Anthropic — Claude Sonnet 4.6 (used by `think` tool)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# fal.ai — hosts openai/gpt-image-2 (the new GPT Image 2 model) and others
# https://fal.ai/dashboard/keys
FAL_KEY=
# Override the endpoint id if you want a different model
# FAL_IMAGE_MODEL=fal-ai/flux/schnell
